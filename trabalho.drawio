<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="fcV5g8Iv98V-_-uWhRJK">
    <mxGraphModel dx="1911" dy="922" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam monochrome false\nskinparam roundcorner 5\n\n&#39; --- INTERFACES E ENUMS ---\ninterface \&quot;DAO&lt;T&gt;\&quot; as DAO {\n  + inserir(obj: T): T\n  + atualizar(obj: T): T\n  + deletar(id: int): void\n  + buscar(id: int): T\n  + buscarTodos(): ArrayList&lt;T&gt;\n}\n\nenum TipoPalpite {\n  CASA\n  EMPATE\n  FORA\n}\n\nenum StatusEvento {\n  ABERTO\n  ENCERRADO\n}\n\nenum StatusAposta {\n  PENDENTE\n  GANHA\n  PERDIDA\n}\n\n&#39; --- ENTIDADES DE NEGÓCIO (MODEL) ---\nclass Usuario {\n  - id: int\n  - nome: String\n  - login: String\n  - senha: String\n  - saldo: double\n  - ehAdmin: boolean\n}\n\nclass Evento {\n  - id: int\n  - timeCasa: String\n  - timeFora: String\n  - oddCasa: double\n  - oddEmpate: double\n  - oddFora: double\n  - status: StatusEvento\n  - resultadoFinal: TipoPalpite\n}\n\nclass Aposta {\n  - id: int\n  - usuarioId: int\n  - eventoId: int\n  - valorApostado: double\n  - palpite: TipoPalpite\n  - status: StatusAposta\n  - ganhoPotencial: double\n}\n\n&#39; --- ACESSO A DADOS (DAO) ---\nclass BD {\n  - connection: Connection\n  - DBNAME: String\n  - LOGIN: String\n  - URL: String\n  - SENHA: String\n  + getConnection(): boolean\n  + close(): void\n}\n\nclass UsuarioDAO {\n  - bd: BD\n  + buscarPorLoginESenha(login: String, senha: String): Usuario\n}\n\nclass EventoDAO {\n  - bd: BD\n  + listarEventosAbertos(): ArrayList&lt;Evento&gt;\n}\n\nclass ApostaDAO {\n  - bd: BD\n  + listarApostasPorUsuario(usuarioId: int): ArrayList&lt;Aposta&gt;\n}\n\n&#39; --- REGRA DE NEGÓCIO (SERVICE) ---\nclass FinanceiroService {\n  - usuarioDAO: UsuarioDAO\n  - apostaDAO: ApostaDAO\n  - eventoDAO: EventoDAO\n  + calcularOverround(oddCasa: double, oddEmpate: double, oddFora: double): double\n  + processarAposta(u: Usuario, e: Evento, valor: double, palpite: TipoPalpite): boolean\n  + encerrarEvento(e: Evento, resultadoReal: TipoPalpite): Evento\n}\n\n&#39; --- INTERFACE GRÁFICA (VIEWS - SWING) ---\nclass LoginView {\n  - txtLogin: JTextField\n  - txtSenha: JPasswordField\n  - btnEntrar: JButton\n  - lblMensagem: JLabel\n  + realizarLogin(): void\n}\n\nclass DashboardApostadorView {\n  - usuarioLogado: Usuario\n  - lblBoasVindas: JLabel\n  - lblSaldo: JLabel\n  - btnApostar: JButton\n  - btnMinhasApostas: JButton\n  - btnSair: JButton\n  + atualizarLabelSaldo(): void\n  + abrirTelaNovaAposta(): void\n  + abrirTelaMinhasApostas(): void\n}\n\nclass DashboardAdminView {\n  - lblTitulo: JLabel\n  - btnCadastrarEvento: JButton\n  - btnEncerrarEvento: JButton\n  - btnSair: JButton\n  + abrirTelaCadastroEvento(): void\n  + abrirTelaEncerramentoEvento(): void\n}\n\nclass Main {\n  + {static} main(args: String[]): void\n}\n\n&#39; ==========================================\n&#39; RELACIONAMENTOS SEMÂNTICOS\n&#39; ==========================================\n\n&#39; 1. Implementações de Interface (Tracejada com seta vazada)\nUsuarioDAO ..|&gt; DAO\nEventoDAO ..|&gt; DAO\nApostaDAO ..|&gt; DAO\n\n&#39; 2. Dependência do Banco de Dados\nUsuarioDAO ..&gt; BD\nEventoDAO ..&gt; BD\nApostaDAO ..&gt; BD\n\n&#39; 3. Associações Estruturais (1 para N)\nUsuario \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Aposta\nEvento \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Aposta\n\n&#39; 4. Uso de Enums\nEvento --&gt; StatusEvento\nEvento --&gt; TipoPalpite\nAposta --&gt; TipoPalpite\nAposta --&gt; StatusAposta\n\n&#39; 5. Dependências do Service com os DAOs\nFinanceiroService ..&gt; UsuarioDAO\nFinanceiroService ..&gt; ApostaDAO\nFinanceiroService ..&gt; EventoDAO\n\n&#39; 6. Comunicação entre View e Backend\nLoginView ..&gt; UsuarioDAO\nLoginView ..&gt; DashboardApostadorView : \&quot;Abre\&quot;\nLoginView ..&gt; DashboardAdminView : \&quot;Abre\&quot;\n\nDashboardApostadorView ..&gt; EventoDAO\nDashboardApostadorView ..&gt; ApostaDAO\nDashboardApostadorView ..&gt; FinanceiroService\n\nDashboardAdminView ..&gt; EventoDAO\nDashboardAdminView ..&gt; FinanceiroService\n\n&#39; 7. Inicialização do Sistema\nMain ..&gt; LoginView : \&quot;Inicia (invokeLater)\&quot;\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="WM7xI3jHelSZccdX-vZn-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1219" width="1474" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
